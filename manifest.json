{
  "manifest_version": 3,
  "name": "Google Search Site Blocker",
  "version": "1.0",
  "description": "Excludes specific websites from Google Search results by appending -site: to the query.",
  "permissions": [
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
